# Ring and bar settings
ring-width=8.0
verif-size=24
time-size=32
date-size=16

# Positioning
timepos="ix-400:iy+10"
datepos="tx:ty+40"
verifpos="ix+5:iy+55"

# Extra effects
blur=0.5
indicator=true

