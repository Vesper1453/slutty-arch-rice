# Image to use for lockscreen (will be blurred)
# Set by wallpaper setter
 wallpaper_cmd="feh --bg-fill"

# Lockscreen appearance - defaults, overridden by mode switcher
insidecolor=00000000
ringcolor=ff1493ff
keyhlcolor=ff69b4ff
bshlcolor=ff0000ff
separatorcolor=00000000
insidevercolor=ff1493ff
insidewrongcolor=ff0000ff
ringvercolor=ff69b4ff
ringwrongcolor=ff0000ff
verifcolor=ffb6c1ff
timecolor=ffb6c1ff
datecolor=ff69b4ff
loginbox=1a0a2e
loginshadow=000000
locktext="Type password to unlock, slut..."

# Font settings
font="JetBrainsMono Nerd Font"
