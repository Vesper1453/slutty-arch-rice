# Function to display the menu and handle selection
show_menu() {
    # Read current mode for theming
    CURRENT_MODE_FILE="$HOME/.config/arch-rice-mode"
    CURRENT_MODE=$(cat "$CURRENT_MODE_FILE" 2>/dev/null || echo "degenerate")
    
    # Theme selection
    local theme="$HOME/.config/rofi/themes/degenerate.rasi"
    local prompt="💋 Choose Your Sin 💋"
    
    if [[ "$CURRENT_MODE" == "horny" ]]; then
        theme="$HOME/.config/rofi/themes/horny.rasi"
        prompt="🔥 Choose Your Pleasure 🔥"
    elif [[ "$CURRENT_MODE" == "normal" ]]; then
        theme="$HOME/.config/rofi/themes/normal.rasi"
        prompt="Select Bookmark"
    fi
    
    # Build the menu with sexy categories
    local selection=$(echo -e "$(get_menu_items)" | rofi \
        -dmenu \
        -i \
        -p "$prompt" \
        -theme "$theme" \
        -kb-row-select "Tab" \
        -kb-row-tab "" \
        -markup-rows \
        -eh 2 \
        -lines 20 \
        -width 50 \
        -location 0 \
        -yoffset -100 \
        -font "JetBrainsMono Nerd Font 14")
    
    # Check if user cancelled
    [[ -z "$selection" ]] && return
    
    # Extract URL from selection
    handle_selection "$selection"
}

