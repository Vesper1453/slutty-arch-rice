# Handle the selection
handle_selection() {
    local selection="$1"
    
    # Extract URL (second field after |)
    local url=$(echo "$selection" | cut -d'|' -f2)
    local name=$(echo "$selection" | cut -d'|' -f1 | sed 's/^[^ ]* //')  # Remove emoji
    
    # Handle special actions
    case "$url" in
        random)
            open_random_site
            ;;
        lock)
            ~/.local/bin/lock-screen
            ;;
        degenerate|horny|normal)
            ~/.local/bin/switch-mode "$url"
            notify-send "💋 MODE SWITCHED 💋" "Changed to $url mode! Get ready for filth!"
            ;;
        https://*)
            open_url "$url" "$name"
            ;;
        *)
            notify-send "❌ ERROR" "Invalid selection: $selection"
            ;;
    esac
}

# Open a specific URL
open_url() {
    local url="$1"
    local name="${2:-Porn Site}"
    
    # Open in default browser
    xdg-open "$url" &
    
    # Show confirmation notification
    notify-send "🍆 OPENING $name 🍆" "Loading your filth... enjoy! 💋" -t 3000
}

# Open a random porn site for the adventurous slut
open_random_site() {
    local sites=(
        "https://pornhub.com"
        "https://xvideos.com"
        "https://chaturbate.com"
        "https://hentaihaven.org"
        "https://rule34.xxx"
        "https://spankbang.com"
        "https://xhamster.com"
    )
    
    local idx=$((RANDOM % ${#sites[@]}))
    local url="${sites[$idx]}"
    
    xdg-open "$url" &
    notify-send "🎲 RANDOM PORN ACTIVATED 🎲" "Surprise! Enjoy your random filth! 💋🔥" -t 3000
}

# Show welcome notification on first open
show_welcome() {
    notify-send "💋 WELCOME TO YOUR SINFUL BOOKMARKS 💋" \
