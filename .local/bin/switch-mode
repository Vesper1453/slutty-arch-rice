# Apply mode switch with maximum slut energy
apply_mode() {
    local mode=$1
    
    echo "Switching to $mode mode... get ready you filthy slut! 💋"
    
    case $mode in
        degenerate)
            update_i3_mode "$mode" DEGENERATE_COLORS
            update_polybar "$mode"
            update_alacritty "$mode"
            update_rofi "$mode"
            update_dunst "$mode" DEGENERATE_COLORS
            update_picom "$mode"
            update_wallpaper "$mode"
            print_degenerate_banner
            send_slutty_notification "degenerate"
            ;;
        horny)
            update_i3_mode "$mode" HORNY_COLORS
            update_polybar "$mode"
            update_alacritty "$mode"
            update_rofi "$mode"
            update_dunst "$mode" HORNY_COLORS
            update_picom "$mode"
            update_wallpaper "$mode"
            print_horny_banner
            send_slutty_notification "horny"
            ;;
        normal)
            update_i3_mode "$mode" NORMAL_COLORS
            update_polybar "$mode"
            update_alacritty "$mode"
            update_rofi "$mode"
            update_dunst "$mode" NORMAL_COLORS
            update_picom "$mode"
            update_wallpaper "$mode"
            print_normal_banner
            send_slutty_notification "normal"
            ;;
    esac
    
    # Save current mode
    echo "$mode" > "$CURRENT_MODE_FILE"
    
    # Reload i3 configuration
    i3-msg reload
    
    # Restart polybar
    "$CONFIG_DIR/polybar/launch.sh"
    
    # Restart dunst
    killall dunst 2>/dev/null || true
    dunst &
    
    # Restart picom
    killall picom 2>/dev/null || true
    sleep 0.5
    picom --config "$CONFIG_DIR/picom/picom.conf" -b
    
    # Update lockscreen colors
    ~/.local/bin/update-mode-lockscreen
    
    echo "Mode switch complete you dirty slut! 💋🔥🍆"
