    local gaps_comment=""
    local mode_name_upper="${mode^^}"
    
    case $mode in
        degenerate)
            slut_comment="DEGENERATE MODE 💋🔥🍆 - Maximum pornographic slut energy"
            gaps_comment="Wide open gaps for maximum sluttiness"
            ;;
        horny)
            slut_comment="HORNY MODE 🔥💦 - Warm, teasing, dripping with desire"
            gaps_comment="Medium gaps, teasing and ready"
            ;;
        normal)
            slut_comment="NORMAL MODE 💼✨ - Clean, professional, sophisticated"
            gaps_comment="Minimal gaps, hiding the filth"
            ;;
    esac
    
    cat > "$CONFIG_DIR/i3/mode.conf" << EOF
# ╔══════════════════════════════════════════════════════════════════════════╗
# ║         MODE-SPECIFIC THEME CONFIGURATION - $mode_name_upper MODE        ║
# ║         $slut_comment                                                    ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# Color Configuration - picked by a true slut
set \$bg ${colors[bg]}           # Background color
set \$border ${colors[border]}       # Border color  
set \$border_active ${colors[border_active]} # Active window border
set \$text ${colors[fg]}            # Text color
set \$urgent ${colors[urgent]}       # Urgent/warning color
set \$indicator ${colors[primary]}  # Indicator color

# Client colors                    border     background  text        indicator  child_border
client.focused                     \$border_active \$bg      \$text       \$indicator \$border_active
client.focused_inactive            \$border     \$bg        \$text       \$indicator \$border
client.unfocused                   \$border     \$bg        \$text       \$indicator \$border
client.urgent                      \$urgent     \$urgent    #ffffff     \$indicator \$urgent
client.placeholder                 #000000     #0c0c0c    #ffffff     #000000    #0c0c0c

client.background                  ${colors[bg]}

# Gaps configuration - $gaps_comment
$(if [[ "$mode" == "degenerate" ]]; then
    echo "gaps inner 15  # Wide open, gaping"
    echo "gaps outer 5   # Exposed edges"
elif [[ "$mode" == "horny" ]]; then
    echo "gaps inner 10  # Teasing gaps"
    echo "gaps outer 3   # Subtle exposure"
else
    echo "gaps inner 8   # Tight and clean"
    echo "gaps outer 0   # No exposure"
fi)

# Mode indicator notification - let everyone know what a slut you are
bindsym \$mod+m exec notify-send "$mode_name_upper MODE ACTIVE" "$(
case $mode in
    degenerate) echo "💋 Pure, unfiltered SLUT ENERGY! Time to get FILTHY! 🔥🍆" ;;
    horny) echo "🔥 Getting WARM and WET! Dripping with desire! 💦" ;;
    normal) echo "💼 Back to pretending to be CIVILIZED... your filthy secrets are safe! ✨" ;;
esac)"
EOF
}

# Update polybar configuration
update_polybar() {
    local mode=$1
    cp "$THEME_DIR/$mode/polybar/config.ini" "$CONFIG_DIR/polybar/config.ini"
    
    # Update the launch script to use current mode
    sed -i "s/CURRENT_MODE=.*$/CURRENT_MODE=$mode/" "$CONFIG_DIR/polybar/launch.sh"
}

# Update alacritty configuration
update_alacritty() {
    local mode=$1
    if [[ "$mode" == "degenerate" ]]; then
        cp "$CONFIG_DIR/alacritty/alacritty.yml" "$CONFIG_DIR/alacritty/alacritty.yml.bak" 2>/dev/null || true
    else
        cp "$THEME_DIR/$mode/alacritty.yml" "$CONFIG_DIR/alacritty/alacritty.yml"
    fi
}

# Update rofi configuration
update_rofi() {
    local mode=$1
    cp "$CONFIG_DIR/rofi/themes/$mode.rasi" "$CONFIG_DIR/rofi/config.rasi"
}

# Update dunst notification colors
update_dunst() {
    local mode=$1
    local -n colors=$2
    
    # Update dunstrc with mode-specific colors
    sed -i "s/frame_color = .*/frame_color = \"${colors[primary]}\"/" "$CONFIG_DIR/dunst/dunstrc"
    sed -i "s/background = \"#[a-fA-F0-9]*/background = \"${colors[bg]}/g" "$CONFIG_DIR/dunst/dunstrc"
    sed -i "s/foreground = \"#[a-fA-F0-9]*/foreground = \"${colors[fg]}/g" "$CONFIG_DIR/dunst/dunstrc"
}

# Update wallpaper
update_wallpaper() {
    local mode=$1
    local wallpaper_dir="$THEME_DIR/$mode/wallpapers"
    
    # Find a random wallpaper from the mode's wallpaper directory
    if [[ -d "$wallpaper_dir" ]]; then
        local wallpaper=$(find "$wallpaper_dir" -type f \( -name "*.jpg" -o -name "*.png" -o -name "*.jpeg" \) 2>/dev/null | shuf -n 1)
        if [[ -n "$wallpaper" ]]; then
            feh --bg-scale "$wallpaper"
        fi
    fi
}

# Update picom opacity based on mode
update_picom() {
    local mode=$1
    
    case $mode in
        degenerate)
            sed -i 's/inactive-opacity = .*/inactive-opacity = 0.80;/' "$CONFIG_DIR/picom/picom.conf"
            sed -i 's/active-opacity = .*/active-opacity = 0.92;/' "$CONFIG_DIR/picom/picom.conf"
            ;;
        horny)
            sed -i 's/inactive-opacity = .*/inactive-opacity = 0.85;/' "$CONFIG_DIR/picom/picom.conf"
            sed -i 's/active-opacity = .*/active-opacity = 0.93;/' "$CONFIG_DIR/picom/picom.conf"
            ;;
        normal)
            sed -i 's/inactive-opacity = .*/inactive-opacity = 0.88;/' "$CONFIG_DIR/picom/picom.conf"
            sed -i 's/active-opacity = .*/active-opacity = 0.95;/' "$CONFIG_DIR/picom/picom.conf"
            ;;
    esac
}

