#!/bin/bash
# ╔══════════════════════════════════════════════════════════════════════════╗
# ║          📥 PORN DOWNLOADER - yt-dlp Wrapper for Tube Sites 💋           ║
# ║    Simplified downloading from adult video platforms                    ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# Configuration
DOWNLOAD_DIR="${DOWNLOAD_DIR:-$HOME/Stash/Videos}"
CONFIG_DIR="$HOME/.config/yt-dlp"
CONFIG_FILE="$CONFIG_DIR/porn.conf"

# Colors
PINK='\033[38;5;205m'
PURPLE='\033[38;5;141m'
GREEN='\033[38;5;82m'
RED='\033[38;5;196m'
RESET='\033[0m'

show_banner() {
    echo -e "${PURPLE}"
    cat << 'EOF'
    ____  ____  ____  _   ____   ____                           __            
   / __ \/ __ \/ __ \/ | / / /  / __ \_________ _____  ____  / /__________ 
  / /_/ / /_/ / / / /  |/ / /  / /_/ / ___/ __ `/ __ \/ __ \/ __/ ___/ __ \
 / ____/ _, _/ /_/ / /|  / /  / ____/ /  / /_/ / /_/ / / / / /_/ /  / /_/ /
/_/   /_/ |_|\____/_/ |_/ /  /_/   /_/   \__,_/\____/_/ /_/\__/_/   \____/ 
                                                                           
     💋 Downloading Your Favorite Content 💋
EOF
    echo -e "${RESET}"
}

show_help() {
    echo "Usage: porn-downloader [OPTIONS] <URL>"
    echo ""
    echo "Options:"
    echo "  -q, --quality      Video quality (best/worst/1080p/720p)"
    echo "  -o, --output       Output directory (default: ~/Stash/Videos)"
    echo "  -p, --playlist     Download entire playlist/channel"
    echo "  -a, --audio-only   Download audio only (for ASMR)"
    echo "  -n, --no-metadata  Skip metadata embedding"
    echo "  -c, --cookies      Use cookies file for authenticated sites"
    echo "  -h, --help         Show this help"
    echo ""
    echo "Examples:"
    echo "  porn-downloader "https://..."
    echo "  porn-downloader -q 1080p "https://..."
    echo "  porn-downloader -p "https://.../playlist"
    echo "  porn-downloader -c ~/.cookies.txt "https://..."
}

# Setup yt-dlp config
setup_config() {
    mkdir -p "$CONFIG_DIR"
    
    cat > "$CONFIG_FILE" << 'EOF'
# yt-dlp configuration for adult content downloading

# Output template
-o %(uploader)s/%(title)s.%(ext)s

# Download settings
--no-overwrites
--continue
--fragment-retries 10
--retries 10
--buffer-size 16K

# Quality settings (select best)
-f "bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best"

# Concurrent fragments for faster downloads
--concurrent-fragments 4

# Don't write description files
--no-write-description
--no-write-info-json
--no-write-thumbnail

# Merge output format
--merge-output-format mp4

# Embed subtitles if available
--embed-subs
--sub-langs en

# Progress template
--progress-template "download-title:%(info.title)s"
--progress-template "download:%(progress.downloaded_bytes)s/%(progress.total_bytes)s"

# Geo-bypass
--geo-bypass

# User agent
--user-agent "Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36"

# Force IPv4 (sometimes helps with certain sites)
--force-ipv4

# Cookies from browser (if needed)
# --cookies-from-browser firefox
EOF
    
    echo -e "${GREEN}✓ Created yt-dlp config:${RESET} $CONFIG_FILE"
}

# Check dependencies
check_deps() {
    if ! command -v yt-dlp &> /dev/null; then
        echo -e "${RED}yt-dlp not installed!${RESET}"
        echo "Install with: sudo pacman -S yt-dlp"
        exit 1
    fi
    
    mkdir -p "$DOWNLOAD_DIR"
}

# Download video
download_video() {
    local url="$1"
    local quality="$2"
    local audio_only="$3"
    local playlist="$4"
    local no_metadata="$5"
    local cookies="$6"
    local output_dir="$7"
    
    local opts=()
    
    # Base options
    opts+=("--config-location" "$CONFIG_FILE")
    
    # Quality
    case "$quality" in
        best)
            opts+=("-f" "bestvideo+bestaudio/best")
            ;;
        worst)
            opts+=("-f" "worst")
            ;;
        1080p|1080)
            opts+=("-f" "bestvideo[height<=1080]+bestaudio/best[height<=1080]")
            ;;
        720p|720)
            opts+=("-f" "bestvideo[height<=720]+bestaudio/best[height<=720]")
            ;;
        480p|480)
            opts+=("-f" "bestvideo[height<=480]+bestaudio/best[height<=480]")
            ;;
    esac
    
    # Audio only
    if [[ "$audio_only" == "true" ]]; then
        opts+=("-x" "--audio-format" "mp3" "--audio-quality" "0")
    fi
    
    # Playlist
    if [[ "$playlist" != "true" ]]; then
        opts+=("--no-playlist")
    fi
    
    # No metadata
    if [[ "$no_metadata" == "true" ]]; then
        opts+=("--no-embed-metadata")
    fi
    
    # Cookies
    if [[ -n "$cookies" && -f "$cookies" ]]; then
        opts+=("--cookies" "$cookies")
    fi
    
    # Output directory
    opts+=("-o" "$output_dir/%(title)s.%(ext)s")
    
    # Print info
    echo -e "${PINK}Downloading from:${RESET} $url"
    echo -e "${PURPLE}Quality:${RESET} ${quality:-best}"
    echo -e "${PURPLE}Output:${RESET} $output_dir"
    echo ""
    
    # Execute download
    yt-dlp "${opts[@]}" "$url"
    
    if [[ $? -eq 0 ]]; then
        echo ""
        echo -e "${GREEN}✓ Download complete!${RESET}"
        return 0
    else
        echo ""
        echo -e "${RED}✗ Download failed${RESET}"
        return 1
    fi
}

# Interactive mode
interactive_mode() {
    echo -e "${PINK}Interactive Download Mode${RESET}"
    echo ""
    
    read -p "Enter URL: " url
    
    if [[ -z "$url" ]]; then
        echo -e "${RED}No URL provided${RESET}"
        return 1
    fi
    
    echo ""
    echo "Select quality:"
    select quality in "best" "1080p" "720p" "480p" "worst"; do
        break
    done
    
    echo ""
    read -p "Download playlist? (y/N): " playlist_yn
    local playlist=false
    [[ "$playlist_yn" =~ ^[Yy]$ ]] && playlist=true
    
    echo ""
    read -p "Audio only? (y/N): " audio_yn
    local audio_only=false
    [[ "$audio_yn" =~ ^[Yy]$ ]] && audio_only=true
    
    download_video "$url" "$quality" "$audio_only" "$playlist" "false" "" "$DOWNLOAD_DIR"
}

# Main
main() {
    show_banner
    check_deps
    
    # Setup config if needed
    [[ ! -f "$CONFIG_FILE" ]] && setup_config
    
    # No arguments - interactive mode
    if [[ $# -eq 0 ]]; then
        interactive_mode
        exit $?
    fi
    
    local quality="best"
    local audio_only=false
    local playlist=false
    local no_metadata=false
    local cookies=""
    local output_dir="$DOWNLOAD_DIR"
    local url=""
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -q|--quality)
                quality="$2"
                shift 2
                ;;
            -o|--output)
                output_dir="$2"
                mkdir -p "$output_dir"
                shift 2
                ;;
            -p|--playlist)
                playlist=true
                shift
                ;;
            -a|--audio-only)
                audio_only=true
                shift
                ;;
            -n|--no-metadata)
                no_metadata=true
                shift
                ;;
            -c|--cookies)
                cookies="$2"
                shift 2
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            http*)
                url="$1"
                shift
                ;;
            *)
                echo "Unknown option: $1"
                show_help
                exit 1
                ;;
        esac
    done
    
    if [[ -z "$url" ]]; then
        echo -e "${RED}Error:${RESET} No URL provided!"
        show_help
        exit 1
    fi
    
    download_video "$url" "$quality" "$audio_only" "$playlist" "$no_metadata" "$cookies" "$output_dir"
}

main "$@"
